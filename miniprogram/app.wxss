/**app.wxss - 全局样式**/
page {
  --primary-color: #1677ff;
  --primary-gradient: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  --success-color: #52c41a;
  --warning-color: #faad14;
  --danger-color: #ff4d6a;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-placeholder: #999999;
  --bg-color: #f7f8fa;
  --border-color: #e8e8e8;
  --card-radius: 16rpx;
  --transition: all 0.2s ease;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: var(--card-radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: var(--transition);
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.06);
}

/* 主要按钮 */
.btn-primary {
  background: var(--primary-gradient);
  color: #ffffff;
  border: none;
  border-radius: var(--card-radius);
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  transition: var(--transition);
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.2);
}

.btn-primary::after {
  border: none;
}

/* 次要按钮 */
.btn-default {
  background-color: #ffffff;
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--card-radius);
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
  transition: var(--transition);
}

.btn-default:active {
  background-color: var(--bg-color);
  transform: scale(0.98);
}

.btn-default::after {
  border: none;
}

/* 危险按钮 */
.btn-danger {
  background-color: var(--danger-color);
  color: #ffffff;
  border: none;
  border-radius: var(--card-radius);
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
  transition: var(--transition);
}

.btn-danger:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-danger::after {
  border: none;
}

/* 价格颜色 */
.price {
  color: var(--danger-color);
  font-size: 32rpx;
  font-weight: bold;
}

/* 库存颜色 */
.stock {
  color: var(--success-color);
}

.stock-zero {
  color: var(--danger-color);
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  transition: var(--transition);
}

.input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(22, 119, 255, 0.1);
}

.input-placeholder {
  color: var(--text-placeholder);
}

/* 状态徽章 */
.badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.badge-success {
  color: var(--success-color);
  background-color: #f6ffed;
}

.badge-warning {
  color: var(--warning-color);
  background-color: #fffbe6;
}

.badge-danger {
  color: var(--danger-color);
  background-color: #fff1f5;
}

.badge-info {
  color: var(--primary-color);
  background-color: #e6f4ff;
}

.badge-default {
  color: var(--text-placeholder);
  background-color: #f5f5f5;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-placeholder);
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-placeholder);
  font-size: 28rpx;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 24rpx 0;
}

/* 页面标题 */
.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 32rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid var(--primary-color);
}

/* 标签 */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  background-color: var(--bg-color);
  color: var(--text-secondary);
  margin-right: 12rpx;
}
