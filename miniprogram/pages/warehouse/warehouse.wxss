.warehouse-header {
  margin: 24rpx;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: var(--card-radius);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.header-top {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.warehouse-name {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-right: 20rpx;
}

.public-badge {
  font-size: 22rpx;
  color: var(--success-color);
  background-color: #f6ffed;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.private-badge {
  font-size: 22rpx;
  color: var(--text-placeholder);
  background-color: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.warehouse-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.owner-info {
  display: flex;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.owner-avatar-wrapper {
  margin-right: 16rpx;
}

.owner-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.owner-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.25);
}

.owner-avatar-placeholder text {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

.owner-name {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 操作按钮 */
.action-bar {
  padding: 0 24rpx 24rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 20rpx rgba(22, 119, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary:active {
  transform: scale(0.98);
}

/* 购物车悬浮按钮 */
.cart-float-btn {
  position: fixed;
  right: 36rpx;
  bottom: 200rpx;
  width: 112rpx;
  height: 112rpx;
  background: var(--primary-gradient);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.4);
  z-index: 100;
  transition: var(--transition);
}

.cart-float-btn:active {
  transform: scale(0.92);
}

.cart-icon {
  font-size: 52rpx;
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  background-color: var(--danger-color);
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 20rpx;
  text-align: center;
  padding: 0 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 106, 0.4);
}

/* 商品列表 */
.product-section {
  padding: 0 24rpx 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid var(--primary-color);
}

.product-list {
  display: flex;
  flex-direction: column;
}

.product-item {
  background-color: #ffffff;
  border-radius: var(--card-radius);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: var(--transition);
}

.product-item:active {
  transform: scale(0.99);
}

.product-info {
  margin-bottom: 20rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.product-sku {
  font-size: 24rpx;
  color: var(--text-placeholder);
  background-color: var(--bg-color);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.product-detail {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-stock {
  display: flex;
  flex-direction: column;
}

.price {
  font-size: 36rpx;
  color: var(--danger-color);
  font-weight: bold;
}

.stock {
  font-size: 26rpx;
  margin-top: 8rpx;
  color: var(--text-secondary);
}

.stock-zero {
  color: var(--danger-color);
}

.product-actions {
  display: flex;
}

.btn-edit {
  font-size: 26rpx;
  padding: 16rpx 28rpx;
  background-color: var(--bg-color);
  color: var(--text-primary);
  border-radius: 32rpx;
  transition: var(--transition);
}

.btn-edit:active {
  background-color: var(--border-color);
}

.btn-add-cart {
  font-size: 26rpx;
  padding: 16rpx 28rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: 32rpx;
  margin-left: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.25);
}

.btn-add-cart:active {
  transform: scale(0.96);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
}
