.warehouse-header {
  margin: 20rpx;
}

.header-top {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.warehouse-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.public-badge {
  font-size: 22rpx;
  color: #52c41a;
  background-color: #f6ffed;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.private-badge {
  font-size: 22rpx;
  color: #999;
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.warehouse-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.owner-info {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.owner-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  margin-right: 12rpx;
}

.owner-avatar-wrapper {
  margin-right: 12rpx;
}

.owner-avatar-placeholder {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.owner-avatar-placeholder text {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.owner-name {
  font-size: 26rpx;
  color: #666;
}

.action-bar {
  padding: 0 20rpx 20rpx;
}

.cart-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 8rpx;
}

.cart-count {
  font-size: 28rpx;
  color: #666;
}

.cart-float-btn {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #333;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.cart-icon {
  font-size: 48rpx;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  border-radius: 18rpx;
  text-align: center;
  padding: 0 8rpx;
}

.product-section {
  padding: 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
}

.product-item {
  margin-bottom: 20rpx;
}

.product-info {
  margin-bottom: 16rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.product-sku {
  font-size: 24rpx;
  color: #999;
}

.product-detail {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-stock {
  display: flex;
  flex-direction: column;
}

.price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.stock {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.stock-zero {
  color: #ff4d4f;
}

.product-actions {
  display: flex;
}

.btn-edit {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 6rpx;
  margin-left: 16rpx;
}

.btn-add-cart {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 6rpx;
  margin-left: 16rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
