<view class="container">
  <!-- 仓库信息 -->
  <view class="warehouse-header card">
    <view class="header-top">
      <text class="warehouse-name">{{warehouse.name}}</text>
      <text class="public-badge" wx:if="{{warehouse.is_public}}">公开</text>
      <text class="private-badge" wx:else>私密</text>
    </view>
    <view class="warehouse-desc">{{warehouse.description || '暂无描述'}}</view>
    <view class="owner-info" wx:if="{{owner}}">
      <image class="owner-avatar" src="{{owner.avatar}}" />
      <text class="owner-name">{{owner.nickname}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar" wx:if="{{isOwner}}">
    <button class="btn-primary" bindtap="goToAddProduct">添加商品</button>
  </view>

  <!-- 购物车悬浮按钮 -->
  <view class="cart-float-btn" wx:if="{{!isOwner}}" bindtap="goToCart">
    <text class="cart-icon">🛒</text>
    <view class="cart-badge" wx:if="{{cartTotalCount > 0}}">{{cartTotalCount > 99 ? '99+' : cartTotalCount}}</view>
  </view>

  <!-- 商品列表 -->
  <view class="product-section">
    <view class="section-title">商品列表</view>

    <view class="product-list">
      <view class="product-item card" wx:for="{{products}}" wx:key="_id">
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-sku" wx:if="{{item.sku}}">SKU: {{item.sku}}</text>
        </view>

        <view class="product-detail">
          <view class="price-stock">
            <text class="price">¥{{item.price}}</text>
            <text class="stock {{item.stock > 0 ? 'stock' : 'stock-zero'}}">
              库存: {{item.stock}} {{item.unit}}
            </text>
          </view>

          <view class="product-actions">
            <button class="btn-edit" wx:if="{{isOwner}}" data-id="{{item._id}}" bindtap="goToEditProduct">编辑</button>
            <button class="btn-add-cart" wx:if="{{!isOwner}}" data-id="{{item._id}}" bindtap="addToCart">加入购物车</button>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{products.length === 0}}">
      <text class="empty-text">暂无商品</text>
    </view>
  </view>
</view>
