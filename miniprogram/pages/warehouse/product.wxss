.form-section {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 96rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  transition: var(--transition);
}

.form-input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(22, 119, 255, 0.1);
}

.form-textarea {
  width: 100%;
  height: 240rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  transition: var(--transition);
}

.form-textarea:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(22, 119, 255, 0.1);
}

.form-row {
  display: flex;
  justify-content: space-between;
}

.form-row .form-item.half {
  width: 48%;
}

.submit-bar {
  padding: 24rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  transform: scale(0.98);
}

.submit-btn.delete {
  background: linear-gradient(135deg, #ff4d6a 0%, #d9363e 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 77, 106, 0.35);
  margin-bottom: 20rpx;
}
