.action-bar {
  padding: 24rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.warehouse-list {
  padding: 0 24rpx 24rpx;
}

.warehouse-item {
  background-color: #ffffff;
  border-radius: var(--card-radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: var(--transition);
}

.warehouse-item:active {
  transform: scale(0.98);
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.warehouse-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-primary);
  flex: 1;
}

.public-badge {
  font-size: 22rpx;
  color: var(--success-color);
  background-color: #f6ffed;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  margin-left: 16rpx;
}

.public-badge.private {
  color: var(--text-placeholder);
  background-color: #f5f5f5;
}

.warehouse-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.create-time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.toggle-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  background-color: var(--bg-color);
  color: var(--text-primary);
  border-radius: 24rpx;
  transition: var(--transition);
}

.toggle-btn:active {
  background-color: var(--border-color);
}

.empty-state {
  text-align: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 40rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: var(--text-placeholder);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #fff;
  border-radius: var(--card-radius);
  padding: 48rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 40rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  transition: var(--transition);
}

.form-input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(22, 119, 255, 0.1);
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  transition: var(--transition);
}

.form-textarea:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(22, 119, 255, 0.1);
}

.modal-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 48rpx;
}

.modal-actions button {
  flex: 1;
  margin: 0 12rpx;
}
