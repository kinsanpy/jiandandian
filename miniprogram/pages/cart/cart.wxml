<view class="container">
  <!-- 登录提示 -->
  <view class="login-tip" wx:if="{{!hasLogin}}">
    <text>登录后查看购物车</text>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-list" wx:else>
    <block wx:for="{{cartItems}}" wx:key="_id">
      <view class="cart-item card">
        <!-- 选择框 -->
        <view class="item-select" catchtap="onSelectItem" data-index="{{index}}" data-id="{{item._id}}">
          <view class="check-box {{selectedItems[index] ? 'selected' : ''}}"></view>
        </view>

        <!-- 商品信息 -->
        <view class="item-info">
          <text class="item-name">{{item.product_name}}</text>
          <text class="item-warehouse">来自: {{item.warehouse_name}}</text>
          <text class="item-price">¥{{item.price}} / {{item.unit}}</text>
        </view>

        <!-- 数量控制 -->
        <view class="item-actions">
          <view class="quantity-control">
            <view class="qty-btn" catchtap="onMinus" data-index="{{index}}" data-id="{{item._id}}">-</view>
            <text class="qty-value">{{item.quantity}}</text>
            <view class="qty-btn" catchtap="onPlus" data-index="{{index}}" data-id="{{item._id}}">+</view>
          </view>
          <text class="remove-btn" catchtap="removeItem" data-id="{{item._id}}">删除</text>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{cartItems.length === 0}}">
      <text class="empty-text">购物车是空的</text>
      <text class="empty-hint">去逛逛仓库吧~</text>
    </view>
  </view>

  <!-- 底部栏 -->
  <view class="bottom-bar" wx:if="{{cartItems.length > 0}}">
    <view class="select-all" catchtap="onSelectAll">
      <view class="check-box {{isAllSelected ? 'selected' : ''}}"></view>
      <text>全选</text>
    </view>

    <view class="total-info">
      <text class="total-label">合计:</text>
      <text class="total-amount">¥{{totalAmount}}</text>
    </view>

    <button class="checkout-btn {{selectedCount === 0 ? 'disabled' : ''}}" catchtap="checkout">
      结算 ({{selectedCount}})
    </button>
  </view>
</view>
