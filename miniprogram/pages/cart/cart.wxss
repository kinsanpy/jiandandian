.login-tip {
  text-align: center;
  padding: 200rpx 100rpx;
  color: var(--text-placeholder);
  font-size: 28rpx;
}

.cart-list {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: var(--card-radius);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: var(--transition);
}

.cart-item:active {
  transform: scale(0.99);
}

.item-select {
  margin-right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-box {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid var(--border-color);
  border-radius: 50%;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition);
}

.check-box.selected {
  border-color: var(--primary-color);
  background-color: var(--primary-color);
}

.check-box.selected::after {
  content: '✓';
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-warehouse {
  font-size: 24rpx;
  color: var(--text-placeholder);
  display: block;
  margin-bottom: 12rpx;
}

.item-price {
  font-size: 30rpx;
  color: var(--danger-color);
  font-weight: bold;
}

.item-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 20rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  background-color: var(--bg-color);
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 16rpx;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
  border-radius: 50%;
  transition: var(--transition);
}

.qty-btn:active {
  background-color: var(--primary-color);
  color: #fff;
}

.qty-value {
  min-width: 64rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  padding: 0 12rpx;
}

.remove-btn {
  font-size: 26rpx;
  color: var(--text-placeholder);
  padding: 8rpx 16rpx;
  transition: var(--transition);
}

.remove-btn:active {
  color: var(--danger-color);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 40rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 36rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: var(--text-placeholder);
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1rpx solid var(--border-color);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.select-all {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
}

.select-all-text {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.total-info {
  flex: 1;
}

.total-label {
  font-size: 26rpx;
  color: var(--text-placeholder);
  display: block;
  margin-bottom: 4rpx;
}

.total-amount {
  font-size: 40rpx;
  color: var(--danger-color);
  font-weight: bold;
}

.checkout-btn {
  width: 200rpx;
  height: 88rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 20rpx rgba(22, 119, 255, 0.3);
  margin-left: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkout-btn:active {
  transform: scale(0.96);
}

.checkout-btn.disabled {
  background: var(--border-color);
  box-shadow: none;
  color: var(--text-placeholder);
}
