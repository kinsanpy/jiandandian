<view class="container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-info" wx:if="{{userInfo}}">
      <image class="avatar" src="{{userInfo.avatarUrl}}" />
      <text class="nickname">{{userInfo.nickName}}</text>
    </view>
    <button class="login-btn" wx:else open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">
      点击登录
    </button>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToMyWarehouse">
      <text class="menu-icon">📦</text>
      <text class="menu-text">我的仓库</text>
      <text class="menu-badge">{{myWarehouseCount}}</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToMyOrders">
      <text class="menu-icon">📝</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-badge">{{myOrderCount}}</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToReceivedOrders">
      <text class="menu-icon">📥</text>
      <text class="menu-text">收到的订单</text>
      <text class="menu-badge">{{receivedOrderCount}}</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
