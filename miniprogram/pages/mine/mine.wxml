<view class="container">
  <!-- 用户名片 -->
  <view class="profile-card card" bindtap="goToProfile">
    <view class="profile-left">
      <image class="profile-avatar" src="{{profile.avatar}}" wx:if="{{profile.avatar}}" />
      <view class="profile-avatar-placeholder" wx:else>
        <text>{{profile.nickname ? profile.nickname.charAt(0) : (profile.company ? profile.company.charAt(0) : '未')}}</text>
      </view>
    </view>
    <view class="profile-info">
      <view class="profile-nickname">{{profile.nickname || profile.company || '点击完善名片'}}</view>
      <view class="profile-company" wx:if="{{profile.company}}">{{profile.company}}</view>
      <view class="profile-business" wx:if="{{profile.business}}">{{profile.business}}</view>
      <view class="profile-edit-tip" wx:if="{{!profile.nickname && !profile.company && !profile.business}}">点击编辑名片</view>
    </view>
    <view class="profile-arrow">></view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToMyWarehouse">
      <text class="menu-icon">📦</text>
      <text class="menu-text">我的仓库</text>
      <text class="menu-badge">{{myWarehouseCount}}</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToMyOrders">
      <text class="menu-icon">📝</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-badge">{{myOrderCount}}</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToReceivedOrders">
      <text class="menu-icon">📥</text>
      <text class="menu-text">收到的订单</text>
      <text class="menu-badge">{{receivedOrderCount}}</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item logout-item" bindtap="onLogout">
      <text class="menu-icon">🚪</text>
      <text class="menu-text logout-text">退出登录</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
