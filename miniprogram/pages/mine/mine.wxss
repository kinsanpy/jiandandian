/* 用户名片 */
.profile-card {
  margin: 24rpx;
  display: flex;
  align-items: center;
  padding: 36rpx;
  background-color: #ffffff;
  border-radius: var(--card-radius);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: var(--transition);
}

.profile-card:active {
  transform: scale(0.98);
}

.profile-left {
  margin-right: 28rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.25);
}

.profile-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 60rpx;
}

.profile-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-avatar-placeholder text {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.profile-info {
  flex: 1;
}

.profile-nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.profile-company {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.profile-business {
  font-size: 26rpx;
  color: var(--text-placeholder);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.profile-arrow {
  font-size: 32rpx;
  color: var(--text-placeholder);
  margin-left: 16rpx;
}

/* 菜单区域 */
.menu-section {
  background-color: #ffffff;
  border-radius: var(--card-radius);
  margin: 0 24rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: var(--transition);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--bg-color);
}

.menu-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-color);
  border-radius: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: var(--text-primary);
}

.menu-badge {
  font-size: 26rpx;
  color: var(--text-placeholder);
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-placeholder);
}

.logout-item {
  margin-top: 24rpx;
}

.logout-item .menu-icon {
  background-color: #fff1f5;
}

.logout-item .menu-text {
  color: var(--danger-color);
}

/* 底部版权 */
.footer {
  text-align: center;
  padding: 60rpx 0;
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.footer text {
  display: block;
  margin-bottom: 8rpx;
}
