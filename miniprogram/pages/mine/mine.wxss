.user-section {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 60rpx 30rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.nickname {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.login-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 35rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.menu-section {
  background-color: #fff;
  border-radius: 16rpx;
  margin: 0 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-badge {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.logout-item {
  margin-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.logout-text {
  color: #ff4d4f;
}
