.menu-section {
  background-color: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-badge {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.logout-item {
  margin-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.logout-text {
  color: #ff4d4f;
}

/* 用户名片 */
.profile-card {
  margin: 20rpx;
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.profile-left {
  margin-right: 24rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
}

.profile-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-avatar-placeholder text {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.profile-info {
  flex: 1;
}

.profile-company {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.profile-business {
  font-size: 26rpx;
  color: #999;
}

.profile-nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.profile-edit-tip {
  font-size: 24rpx;
  color: #999;
}

.profile-arrow {
  font-size: 32rpx;
  color: #ccc;
}
