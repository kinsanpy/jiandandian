.profile-card {
  padding: 48rpx 40rpx;
}

/* 头像 */
.avatar-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.avatar-wrapper {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--bg-color);
  border: 6rpx solid #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  transition: var(--transition);
}

.avatar-wrapper:active {
  transform: scale(0.95);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--primary-gradient);
}

.avatar-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.avatar-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单项 */
.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 96rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  transition: var(--transition);
}

.form-input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(22, 119, 255, 0.1);
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  transition: var(--transition);
}

.form-textarea:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(22, 119, 255, 0.1);
}

/* 保存按钮 */
.save-btn {
  margin-top: 60rpx;
  height: 96rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.25);
}
