.container {
  min-height: 100vh;
  background: var(--primary-gradient);
  padding: 24rpx 40rpx 40rpx;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.app-logo {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 24rpx;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.app-logo text {
  font-size: 72rpx;
}

.app-title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
  letter-spacing: 6rpx;
}

.app-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 搜索区域 */
.search-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 100rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.search-bar {
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 80rpx;
  border: none;
  background-color: var(--bg-color);
  border-radius: 40rpx;
  padding: 0 36rpx;
  font-size: 30rpx;
}

.search-btn {
  width: 120rpx;
  height: 80rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-left: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 仓库列表 */
.warehouse-list {
  padding-bottom: 20rpx;
}

.warehouse-card {
  background-color: #ffffff;
  border-radius: var(--card-radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: var(--transition);
}

.warehouse-card:active {
  transform: scale(0.98);
}

.warehouse-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.warehouse-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-primary);
  flex: 1;
}

.warehouse-badge {
  font-size: 22rpx;
  color: var(--success-color);
  background-color: #f6ffed;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
}

.warehouse-badge.private {
  color: var(--text-placeholder);
  background-color: #f5f5f5;
}

.warehouse-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.warehouse-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.meta-left {
  display: flex;
  align-items: center;
}

.owner-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.owner-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.meta-right {
  font-size: 26rpx;
  color: var(--text-placeholder);
}

.enter-btn {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

/* 创建仓库入口 */
.create-section {
  margin-top: 40rpx;
  text-align: center;
}

.create-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  background-color: rgba(255, 255, 255, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 48rpx;
  color: #fff;
  font-size: 30rpx;
}

.create-btn text {
  margin-right: 8rpx;
}
