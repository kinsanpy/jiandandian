.confirm-section {
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid var(--primary-color);
}

.warehouse-group {
  background-color: #fff;
  border-radius: var(--card-radius);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.warehouse-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
}

.warehouse-name::before {
  content: '🏪';
  margin-right: 12rpx;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.order-item:last-child {
  border-bottom: none;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 30rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.item-price {
  font-size: 26rpx;
  color: var(--text-placeholder);
}

.item-subtotal {
  font-size: 32rpx;
  color: var(--danger-color);
  font-weight: bold;
  margin-left: 20rpx;
}

.remark-section {
  margin: 0 0 24rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: var(--card-radius);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.remark-label {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.remark-input {
  font-size: 28rpx;
  color: var(--text-secondary);
  background-color: var(--bg-color);
  border-radius: 12rpx;
  padding: 20rpx;
  min-height: 80rpx;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1rpx solid var(--border-color);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.total-info {
  flex: 1;
}

.total-label {
  font-size: 26rpx;
  color: var(--text-placeholder);
  display: block;
  margin-bottom: 4rpx;
}

.total-amount {
  font-size: 44rpx;
  color: var(--danger-color);
  font-weight: bold;
}

.submit-btn {
  width: 220rpx;
  height: 88rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 20rpx rgba(22, 119, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  transform: scale(0.96);
}

/* 订单列表 */
.order-list {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.order-card {
  background-color: #ffffff;
  border-radius: var(--card-radius);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  transition: var(--transition);
}

.order-card:active {
  transform: scale(0.99);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.card-warehouse {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  display: flex;
  align-items: center;
}

.card-warehouse::before {
  content: '🏪';
  margin-right: 10rpx;
}

.card-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-pending {
  color: var(--warning-color);
  background-color: #fffbe6;
}

.status-producing {
  color: var(--primary-color);
  background-color: #e6f4ff;
}

.status-shipped {
  color: var(--success-color);
  background-color: #f6ffed;
}

.status-completed {
  color: var(--text-placeholder);
  background-color: #f5f5f5;
}

.status-cancelled {
  color: var(--danger-color);
  background-color: #fff1f5;
}

.card-products {
  margin-bottom: 20rpx;
}

.card-product {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.card-product:last-child {
  border-bottom: none;
}

.card-product .product-name {
  font-size: 30rpx;
  color: var(--text-primary);
  flex: 1;
  font-weight: 500;
}

.card-product .product-qty {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 24rpx;
  background-color: var(--bg-color);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.card-remark {
  background-color: var(--bg-color);
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.card-remark .remark-label {
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-right: 8rpx;
}

.card-remark .remark-value {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.card-time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.card-total {
  font-size: 36rpx;
  color: var(--danger-color);
  font-weight: bold;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.action-btn {
  font-size: 26rpx;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  margin-left: 20rpx;
  background-color: var(--bg-color);
  color: var(--text-primary);
  transition: var(--transition);
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn.primary {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.25);
}

.action-btn.danger {
  background-color: #fff1f5;
  color: var(--danger-color);
}

/* 订单详情 */
.order-detail {
  padding: 24rpx;
}

.detail-section {
  background-color: #ffffff;
  border-radius: var(--card-radius);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.detail-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-placeholder);
}

.detail-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-item .item-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.detail-item .item-price {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.detail-total {
  display: flex;
  justify-content: flex-end;
  padding-top: 24rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--danger-color);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 40rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-placeholder);
  font-size: 28rpx;
}
