.confirm-section {
  padding: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.warehouse-group {
  background-color: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.warehouse-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-item:last-child {
  border-bottom: none;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.item-price {
  font-size: 24rpx;
  color: #999;
}

.item-subtotal {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.remark-section {
  margin: 0 20rpx 20rpx;
  padding: 20rpx;
}

.remark-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.remark-input {
  font-size: 28rpx;
  color: #333;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.total-info {
  flex: 1;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-amount {
  font-size: 40rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-left: 8rpx;
}

.submit-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 35rpx;
}

/* 订单列表 */
.order-list {
  padding: 20rpx;
}

.order-item {
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-warehouse {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-pending {
  color: #faad14;
  background-color: #fffbe6;
}

.status-producing {
  color: #1890ff;
  background-color: #e6f7ff;
}

.status-shipped {
  color: #52c41a;
  background-color: #f6ffed;
}

.status-completed {
  color: #999;
  background-color: #f5f5f5;
}

.status-cancelled {
  color: #ff4d4f;
  background-color: #fff1f0;
}

.order-products {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-total {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 6rpx;
  margin-left: 16rpx;
  background-color: #1890ff;
  color: #fff;
}

.action-btn.confirm-btn {
  background-color: #52c41a;
}

.action-btn.cancel-btn {
  background-color: #ff4d4f;
}

/* 订单详情 */
.order-detail {
  padding: 20rpx;
}

.detail-section {
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #999;
}

.detail-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item .item-name {
  font-size: 28rpx;
  color: #333;
}

.detail-item .item-price {
  font-size: 28rpx;
  color: #666;
}

.detail-total {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}
